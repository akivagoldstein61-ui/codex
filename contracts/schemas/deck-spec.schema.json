{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/deck-spec.schema.json",
  "title": "DeckSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "deck_id",
    "slug",
    "title",
    "content_hash",
    "content_version_id",
    "request_id",
    "idempotency_key",
    "created_at"
  ],
  "properties": {
    "version": { "type": "string" },
    "deck_id": { "type": "string", "pattern": "^deck_[a-zA-Z0-9_-]+$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "content_hash": { "type": "string", "minLength": 8 },
    "content_version_id": { "type": "string", "minLength": 8 },
    "request_id": { "type": "string", "minLength": 8 },
    "idempotency_key": { "type": "string", "minLength": 8 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["draft", "approved", "rejected"] },
        "approved_by": { "type": "string" },
        "approved_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
